[
 {guanco, [
   {pool_size, 5},
   {max_overflow, 10}
 ]},
 {mustachioed_llama, [
   {host,         "localhost"},  %% Ollama host; override with -mustachioed_llama host myhost
   {port,         11434},        %% Ollama port; override with -mustachioed_llama port 9999
   {num_ctx,      1024},         %% Ollama context length (tokens); override to 4096+ for real use
   {max_history,  20}            %% Rolling window of messages kept in chat history
 ]}
].
